{
  "name": "claudex-cli",
  "version": "0.1.0",
  "description": "Claude Code UI + OpenAI models. No API key needed.",
  "type": "module",
  "bin": {
    "claudex": "./dist/claudex.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "bundle": "node esbuild.config.mjs",
    "build": "npm run bundle && node scripts/build-binaries.sh",
    "package": "VERSION=$(node -p \"require('./package.json').version\") bash scripts/package-installers.sh"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "open": "^10.1.0",
    "fast-glob": "^3.3.2",
    "chalk": "^5.4.1",
    "figures": "^6.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
